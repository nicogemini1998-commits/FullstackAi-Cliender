NGINX CONFIG

server {
    server_name crm.tudominio.com;
    
    location /api {
        proxy_pass http://127.0.0.1:8000;
    }
    
    location / {
        root /var/www/crm/dist;
        try_files $uri /index.html;
    }
    
    listen 443 ssl;
    # certificados Let's Encrypt aquí
}



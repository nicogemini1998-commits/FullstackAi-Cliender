BASE DE DATOS — ESQUEMA

-- Empresas
CREATE TABLE companies (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  name VARCHAR(255) NOT NULL,
  website VARCHAR(255),
  sector VARCHAR(100),
  city VARCHAR(100),
  employee_count INTEGER,
  digital_score INTEGER,        -- Score 0-100 generado por Claude
  gmb_rating FLOAT,             -- Reseña Google Maps
  gmb_reviews INTEGER,
  has_crm BOOLEAN,
  social_facebook VARCHAR(255),
  social_linkedin VARCHAR(255),
  opportunity_level VARCHAR(10), -- ALTA / MEDIA / BAJA
  opportunity_sales TEXT,
  opportunity_tech TEXT,
  opportunity_av TEXT,
  raw_data JSONB,               -- Datos crudos de Apollo/Apify
  created_at TIMESTAMP DEFAULT NOW()
);

-- Contactos / Decision Makers
CREATE TABLE contacts (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  company_id UUID REFERENCES companies(id),
  name VARCHAR(255),
  role VARCHAR(100),
  email VARCHAR(255),
  phone_mobile VARCHAR(50),
  phone_verified BOOLEAN DEFAULT FALSE,
  phone_source VARCHAR(50),     -- 'apollo' / 'manual' / 'apify'
  linkedin_url VARCHAR(255),
  is_primary BOOLEAN DEFAULT FALSE
);

-- Estados de llamada
CREATE TABLE call_logs (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  contact_id UUID REFERENCES contacts(id),
  company_id UUID REFERENCES companies(id),
  commercial_id UUID,           -- Qué comercial hizo la llamada
  status VARCHAR(20),           -- 'closed' / 'rejected' / 'no_answer'
  notes TEXT,
  called_at TIMESTAMP DEFAULT NOW()
);

-- Usuarios / Comerciales
CREATE TABLE users (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  name VARCHAR(100),
  email VARCHAR(100) UNIQUE,
  password_hash VARCHAR(255),
  role VARCHAR(20) DEFAULT 'commercial'
);


